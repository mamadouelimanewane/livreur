{
  "cli": {
    "version": ">= 5.0.0"
  },
  "build": {
    "user-apk": {
      "android": {
        "buildType": "apk",
        "env": {
          "APP_TARGET": "user"
        }
      }
    },
    "driver-apk": {
      "android": {
        "buildType": "apk",
        "env": {
          "APP_TARGET": "driver"
        }
      }
    },
    "admin-apk": {
      "android": {
        "buildType": "apk",
        "env": {
          "APP_TARGET": "admin"
        }
      }
    },
    "user-preview": {
      "android": {
        "buildType": "apk",
        "distribution": "internal",
        "env": {
          "APP_TARGET": "user"
        }
      }
    },
    "driver-preview": {
      "android": {
        "buildType": "apk",
        "distribution": "internal",
        "env": {
          "APP_TARGET": "driver"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
